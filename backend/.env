# ======================================================
# DATABASE
# ======================================================
# [로컬 실행] Railway 외부 접속 URL 사용:
#   Railway 대시보드 → PostgreSQL 서비스 → Connect 탭 → External 탭
#   → DATABASE_PUBLIC_URL 값을 복사해서 아래에 붙여넣기
#
# 예시 형식:
#   postgresql://postgres:비밀번호@xxxxx.railway.app:포트/railway
#
# DATABASE_URL을 설정하면 아래 개별 파라미터는 무시됨
DATABASE_URL=

# [개별 파라미터] 로컬 PostgreSQL을 직접 설치한 경우 사용
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=banmo
DATABASE_USER=banmo_user
DATABASE_PASSWORD=banmo_pass

# ======================================================
# JWT
# ======================================================
JWT_SECRET=banmo_super_secret_key_2024
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=banmo_refresh_secret_key_2024

# ======================================================
# 카카오 OAuth
# developers.kakao.com → 앱 → 앱 키 → REST API 키
# ======================================================
KAKAO_CLIENT_ID=1415739
KAKAO_REST_API_KEY=0a7a79de08305d6ac37730199e6dcabc
KAKAO_CLIENT_SECRET=deXnBkhZWTzZY3pbdpqW9vTQXyiBRgaO
KAKAO_CALLBACK_URL=http://localhost:3000/auth/callback
KAKAO_FRONTEND_CALLBACK_URL=http://localhost:3000/auth/callback

# ======================================================
# 앱 설정
# ======================================================
FRONTEND_URL=http://localhost:3000
PORT=3001

# ======================================================
# Cloudflare R2 (이미지 업로드) - 로컬 테스트 시 선택사항
# Cloudflare 대시보드 → R2 → 버킷 → API 토큰
# ======================================================
R2_ACCOUNT_ID=여기에Account ID입력
R2_ACCESS_KEY_ID=여기에Access Key ID입력
R2_SECRET_ACCESS_KEY=여기에Secret Access Key입력
R2_BUCKET_NAME=banmo-media
R2_PUBLIC_URL=여기에R2.dev URL입력
R2_ENDPOINT=https://여기에AccountID.r2.cloudflarestorage.com

# ======================================================
# 토스페이먼츠 - 로컬 테스트 시 선택사항
# developers.tosspayments.com에서 발급
# ======================================================
TOSS_SECRET_KEY=test_sk_발급받은키입력필요

# ======================================================
# 이메일 (비밀번호 재설정) - 로컬 테스트 시 선택사항
# Gmail 앱 비밀번호: Google 계정 → 보안 → 2단계 인증 → 앱 비밀번호
# ======================================================
MAIL_USER=your-gmail@gmail.com
MAIL_PASS=gmail-app-password

# ======================================================
# Firebase Admin SDK (FCM 푸시 알림) - 로컬 테스트 시 선택사항
# Firebase Console → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성
# ======================================================
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
